    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "logos",
    "mtaquest",
    "backend",
    "ddd",
    "event-driven"
  ],
