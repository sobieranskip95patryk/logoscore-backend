    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "firebase-admin": "^12.3.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "marked": "^13.0.2",
    "mongoose": "^8.5.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.12.0",
    "pgvector": "^0.2.0",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
