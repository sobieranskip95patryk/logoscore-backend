NODE_ENV=development
PORT=3000

# CORS — frontend serwowany lokalnie (np. file:// lub http://localhost:5500)
CORS_ORIGIN=*

# Postgres
DATABASE_URL=postgresql://logos:logos@localhost:5432/logoscore

# MongoDB (Living Memory — JSON-LD intent graph + audit + documents)
MONGO_URL=mongodb://logos:logos@localhost:27017/?authSource=admin
MONGO_DB=logoscore_intent

# Wybór backendu pamięci intencji: auto | mongo | postgres | memory
MEMORY_BACKEND=auto

# Redis
REDIS_URL=redis://localhost:6379

# Firebase Admin (jedna z opcji)
# 1) Plik service-account.json:
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# 2) Albo zakodowany w Base64 JSON:
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# AI provider (gemini | ollama). Local-first = ollama.
AI_PROVIDER=gemini
AI_API_KEY=
AI_MODEL_ANALYZE=gemini-1.5-flash
AI_MODEL_TTS=gemini-2.5-flash-preview-tts
AI_MODEL_EMBED=text-embedding-004

# Ollama (lokalny LLM, hermetyczny tryb)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

# Pamięć wektorowa (pgvector)
VECTOR_ENABLED=true
VECTOR_DIMENSIONS=768
VECTOR_TOP_K=6

# IntentionalResolver — gęstszy embedding dla celów + akcji
RESOLVER_EMBED_MODEL=mxbai-embed-large
RESOLVER_EMBED_DIM=1024
RESOLVER_MIN_SCORE=0.65
RESOLVER_TOP_K=5
RESOLVER_AUTO_CORRELATE=true
RESOLVER_PARENT_DISCOUNT=0.8

# Retencja audit-trail (sek). Snapshoty omijają TTL.
AUDIT_RETENTION_SECONDS=7776000
AUDIT_SNAPSHOT_EVERY=25

# Domyślne ustawienia auth — pozwól na anonimowych użytkowników (frontend HTML)
ALLOW_ANONYMOUS=true
