# env/.env.example
# Copy to env/.env.development or env/.env.production and fill in real secrets.

NODE_ENV=production
PORT=8080
CORS_ORIGIN=https://your-domain.example.com

DATABASE_URL=postgresql://username:password@postgres:5432/logoscore
MONGO_URL=mongodb://mongo:27017
MONGO_DB=logoscore_intent
REDIS_URL=redis://redis:6379

ALLOW_ANONYMOUS=false
ADMIN_UIDS=

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_AI_MAX=20
BODY_LIMIT=12mb

AI_PROVIDER=gemini
AI_API_KEY=
AI_MODEL_ANALYZE=gemini-1.5-flash
AI_MODEL_TTS=gemini-2.5-flash-preview-tts
AI_MODEL_EMBED=text-embedding-004
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

FIREBASE_SERVICE_ACCOUNT_BASE64=
GOOGLE_APPLICATION_CREDENTIALS=

TELEMETRY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=logoscore-backend
PROMETHEUS_ENABLED=false
